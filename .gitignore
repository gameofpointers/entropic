# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
dist-macos/
src-tauri/target/

# Tauri
src-tauri/gen/
# Bundled runtime binaries (populated by scripts/bundle-runtime.sh).
# Placeholder READMEs are tracked so Tauri's resource globs resolve on
# fresh checkouts and CI without running bundle-runtime.sh first.
src-tauri/resources/bin/*
!src-tauri/resources/bin/README.txt
src-tauri/resources/openclaw-runtime.tar.gz
src-tauri/resources/share/*
!src-tauri/resources/share/placeholders/
src-tauri/resources/share/placeholders/*
!src-tauri/resources/share/placeholders/README.txt
!src-tauri/resources/share/rnn-runtime/
src-tauri/resources/share/rnn-runtime/__pycache__/
!src-tauri/resources/share/rnn-runtime/*.py

# Environment
.env
.env.local
.env.*.local
.env.signing

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Rust
**/*.rs.bk

# Testing
coverage/

# Temp files
*.tmp
*.temp
.cache/
.build/

# Entropic local data (contains API keys)
.entropic-data/
